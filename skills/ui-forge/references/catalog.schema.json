{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ui-forge.dev/schemas/catalog.schema.json",
  "title": "UI Forge catalog",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "kind", "items"],
  "properties": {
    "schemaVersion": {
      "const": "1.0.0"
    },
    "kind": {
      "enum": ["pattern", "anti-pattern", "quality-gate", "product-guide", "stack-guide"]
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/item"
      }
    }
  },
  "$defs": {
    "item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "summary",
        "intent",
        "appliesTo",
        "tags",
        "checks",
        "warnings",
        "exceptions",
        "sourceRefs",
        "level"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$",
          "minLength": 3,
          "maxLength": 72
        },
        "title": {
          "type": "string",
          "minLength": 3,
          "maxLength": 90
        },
        "summary": {
          "type": "string",
          "minLength": 20,
          "maxLength": 220
        },
        "intent": {
          "type": "string",
          "minLength": 20,
          "maxLength": 500
        },
        "appliesTo": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          }
        },
        "tags": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          }
        },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 10,
            "maxLength": 280
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 10,
            "maxLength": 280
          }
        },
        "exceptions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 10,
            "maxLength": 280
          }
        },
        "sourceRefs": {
          "description": "Standards supporting this entry plus the UI Forge synthesis marker. Upstream research influences are documented at topic level in provenance/extraction-map.csv.",
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "wcag-2.2",
              "nextjs",
              "owasp",
              "ui-forge-synthesis"
            ]
          }
        },
        "level": {
          "enum": ["blocking", "recommended", "contextual"]
        }
      }
    }
  }
}
