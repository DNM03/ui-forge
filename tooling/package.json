{
  "name": "@ui-forge/tooling",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "compile": "tsc -p tsconfig.build.json",
    "build:content": "npm run compile && node dist/build.js",
    "validate": "npm run compile && node dist/validate.js",
    "validate:skill": "npm run compile && node dist/validate-skill.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "gray-matter": "^4.0.3",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
